# Fluid Webapp Configuration
# Copy this file to .env and fill in your actual values

# Jira Configuration
JIRA_API_TOKEN=your_jira_api_token_here

# GitHub Configuration
GITHUB_PAT=your_github_personal_access_token_here

# OpenAI / Spring AI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Spring AI Model Configuration (optional, defaults in application.properties)
# SPRING_AI_OPENAI_CHAT_OPTIONS_MODEL=gpt-4
# SPRING_AI_OPENAI_CHAT_OPTIONS_TEMPERATURE=0.7
